{
	"name": "contactly-saas",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "pnpx playwright test",
		"test:unit": "vitest",
		"test:e2e": "pnpx playwright test",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"gen:types": "pnpx supabase gen types typescript --local > src/lib/supabase-types.ts && prettier --write src/lib/supabase-types.ts",
		"seed": "tsx --tsconfig scripts/tsconfig.json scripts/seed.ts",
		"stripe:webhooks": "stripe listen --forward-to localhost:5173/api/stripe/webhook"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.8",
		"@supabase/auth-helpers-sveltekit": "^0.15.0",
		"@supabase/supabase-js": "^2.98.0",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.31.0",
		"flowbite-svelte-icons": "^3.1.0",
		"stripe": "^20.4.1",
		"svelte-french-toast": "1.2.0"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/detect-port": "^2.0.0",
		"@types/node": "^25.3.5",
		"@types/pg": "^8.18.0",
		"@typescript-eslint/eslint-plugin": "^8.56.1",
		"@typescript-eslint/parser": "^8.56.1",
		"autoprefixer": "^10.4.27",
		"detect-port": "^2.1.0",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"pg": "^8.20.0",
		"postcss": "^8.5.8",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"stripe-event-types": "^3.1.0",
		"supabase": "^2.77.0",
		"svelte": "^5.53.7",
		"svelte-check": "^4.4.4",
		"svelte-preprocess": "^6.0.3",
		"sveltekit-superforms": "^2.30.0",
		"tailwindcss": "^4.2.1",
		"tslib": "^2.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"zod": "^4.3.6"
	},
	"packageManager": "pnpm@10.30.3"
}
