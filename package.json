{
	"name": "contactly-saas",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "pnpx playwright test",
		"test:unit": "vitest",
		"test:e2e": "pnpx playwright test",
		"lint": "prettier --plugin-search-dir . --check . && eslint .",
		"format": "prettier --plugin-search-dir . --write .",
		"gen:types": "pnpx supabase gen types typescript --local > src/lib/supabase-types.ts && prettier --write src/lib/supabase-types.ts",
		"seed": "tsx --tsconfig scripts/tsconfig.json scripts/seed.ts",
		"stripe:webhooks": "stripe listen --forward-to localhost:5173/api/stripe/webhook"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.8",
		"@supabase/auth-helpers-sveltekit": "^0.15.0",
		"@supabase/supabase-js": "^2.107.0",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"flowbite": "^4.0.2",
		"flowbite-svelte": "^1.33.1",
		"flowbite-svelte-icons": "^3.1.0",
		"stripe": "^22.2.0",
		"svelte-french-toast": "1.2.0"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.4.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/postcss": "^4.3.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/detect-port": "^2.0.0",
		"@types/node": "^25.9.2",
		"@types/pg": "^8.20.0",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"autoprefixer": "^10.5.0",
		"detect-port": "^2.1.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"pg": "^8.21.0",
		"postcss": "^8.5.15",
		"postcss-load-config": "^6.0.1",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"stripe-event-types": "^3.1.0",
		"supabase": "^2.105.0",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"svelte-preprocess": "^6.0.5",
		"sveltekit-superforms": "^2.30.1",
		"tailwindcss": "^4.3.0",
		"tslib": "^2.8.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"zod": "^4.4.3"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"cookie@<0.7.0": ">=0.7.0",
			"minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
			"rollup@>=4.0.0 <4.59.0": ">=4.59.0",
			"tar@<=7.5.10": ">=7.5.11",
			"devalue@>=5.6.3 <=5.8.0": ">=5.8.1",
			"brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6"
		}
	}
}
